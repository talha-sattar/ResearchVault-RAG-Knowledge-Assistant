# Copy to .env and fill in real values. .env is gitignored - never commit real secrets.

# --- LLM providers ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_CHAT_MODEL=gemini-2.5-flash

# --- Database ---
POSTGRES_USER=researchvault
POSTGRES_PASSWORD=researchvault
POSTGRES_DB=researchvault
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://researchvault:researchvault@localhost:5432/researchvault

# --- Storage paths ---
# Intentionally omitted: data_dir/pdf_dir/chroma_dir default to <repo_root>/data/... computed
# absolutely in app/config.py. Setting them here as relative paths would resolve differently
# depending on the process's cwd (bit us once - don't reintroduce). Only override with an
# ABSOLUTE path if you really need to relocate storage.

# --- arXiv ingestion ---
ARXIV_USER_AGENT=ResearchVault/0.1 (personal research assistant; contact: alientimesg@gmail.com)
ARXIV_RATE_LIMIT_SECONDS=3

# --- App ---
ENV=development
LOG_LEVEL=INFO
